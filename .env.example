# AgriPulse AI - Environment Variables Reference
# Copy this file to .env and fill in your values

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Database server hostname
DB_HOST=localhost

# PostgreSQL port
DB_PORT=5432

# Database name
DB_NAME=agripulse

# Database username
DB_USER=agripulse

# Database password
DB_PASSWORD=agripulse123

# =============================================================================
# API CONFIGURATION
# =============================================================================
# Base URL for API requests
API_BASE_URL=http://localhost:8000/api/v1

# Authentication token for API requests
# IMPORTANT: Change this in production!
API_AUTH_TOKEN=agripulse-hackathon-secret-key-2026

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
# Environment: development, staging, or production
APP_ENV=development

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# =============================================================================
# MOBILE APP CONFIGURATION
# =============================================================================
# Default sales rep ID for mobile app
DEFAULT_REP_ID=REP_0001

# =============================================================================
# SCORING CONFIGURATION
# =============================================================================
# Score date: 'today' for current date, or 'YYYY-MM-DD' for specific date
SCORE_DATE=today

# =============================================================================
# MODEL PATHS (usually don't need to change)
# =============================================================================
# Directory containing ML models
MODELS_DIR=models